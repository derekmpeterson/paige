    "epub",
    "ebook",
    "ai",
    "chatbot",
    "spoiler-free",
    "reading",
    "openrouter",
    "llm",
    "nextjs"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
