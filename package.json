    "@ai-sdk/react": "^3.0.79",
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/typography": "^0.5.20",
    "ai": "^7.0.31",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
