# Choose one: OpenRouter or local llama.cpp
OPENROUTER_API_KEY=your-key-here
MODEL_ID=x-ai/grok-4.3

# For a local OpenAI-compatible server such as llama.cpp.
# Set LLAMA_SERVER_URL to use it instead of OpenRouter (no API key required).
LLAMA_SERVER_URL=http://localhost:8080/v1
LLAMA_MODEL_ID=your-local-model-id
